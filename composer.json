{
  "name": "php/docbook-cs",
  "description": "A static-analysis linter for DocBook XML files",
  "type": "library",
  "license": "Apache-2.0",
  "bin": ["bin/docbook-cs"],
  "require": {
    "php": "^8.5",
    "ext-dom": "*",
    "ext-libxml": "*",
    "ext-simplexml": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "phpstan/phpstan": "^2.1",
    "phpunit/php-code-coverage": "^14.1",
    "squizlabs/php_codesniffer": "^4.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/phpstan-phpunit": "^2.0",
    "shipmonk/dead-code-detector": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "DocbookCS\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DocbookCS\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "@php -r \"exit(extension_loaded('xdebug') || extension_loaded('pcov') ? 0 : 1);\" && XDEBUG_MODE=coverage ./vendor/bin/phpunit --configuration phpunit.xml.dist || ./vendor/bin/phpunit --configuration phpunit.xml.dist --no-coverage",
    "phpstan": "./vendor/bin/phpstan analyse --no-progress",
    "phpcs": "./vendor/bin/phpcs",
    "quality": [
      "@phpcs",
      "@phpstan",
      "@test"
    ]
  },
  "authors": [
    {
      "name": "Jordi Kroon",
      "email": "jordikroon@php.net"
    },
    {
      "name": "DocbookCS contributors",
      "homepage": "https://github.com/php/docbook-cs/graphs/contributors"
    }
  ]
}
